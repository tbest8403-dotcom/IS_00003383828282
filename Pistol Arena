local function isSameTeam(player)
	if not State.TeamCheck then
		return false
	end

	if LocalPlayer.Neutral or player.Neutral then
		return false
	end

	return LocalPlayer.Team ~= nil and player.Team == LocalPlayer.Team
end

local function getCurrentCamera()
	return workspace.CurrentCamera
end

local function getEquippedWeapon()
	local character = LocalPlayer.Character
	local camera = getCurrentCamera()

	if not character or not camera then
		return nil, "WAITING FOR CHARACTER"
	end

	local humanoid = character:FindFirstChildOfClass("Humanoid")

	if not humanoid or humanoid.Health <= 0 then
		return nil, "CHARACTER NOT READY"
	end

	local tool = character:FindFirstChildOfClass("Tool")

	if not tool or not camera:FindFirstChild("Viewmodel") then
		return nil, "EQUIP A WEAPON"
	end

	return tool, nil
end

local function makeWallcheckParams()
	local exclusions = {}
	local character = LocalPlayer.Character

	if character then
		table.insert(exclusions, character)
	end

	local effects = workspace:FindFirstChild("Effects")
	local ragdolls = workspace:FindFirstChild("Ragdolls")

	if effects then
		table.insert(exclusions, effects)
	end

	if ragdolls then
		table.insert(exclusions, ragdolls)
	end

	local params = RaycastParams.new()
	params.FilterType = Enum.RaycastFilterType.Exclude
	params.FilterDescendantsInstances = exclusions
	params.IgnoreWater = true
	return params
end

local function hasClearShot(origin, targetCharacter, aimPart)
	local offset = aimPart.Position - origin

	if offset.Magnitude <= 0.01 or offset.Magnitude > RANGE then
		return false
	end

	local result = workspace:Raycast(origin, offset, makeWallcheckParams())

	if not result then
		-- Some target parts may have CanQuery disabled. With nothing else in the
		-- path, the shot is still unobstructed.
		return true
	end

	return result.Instance:IsDescendantOf(targetCharacter)
end

local function getAimParts(character)
	local names = {
		"HeadHitbox",
		"Head",
		"UpperTorso",
		"Torso",
		"HumanoidRootPart",
	}
	local parts = {}

	for _, name in ipairs(names) do
		local part = character:FindFirstChild(name)

		if part and part:IsA("BasePart") then
			table.insert(parts, part)
		end
	end

	return parts
end

local function findNearestVisibleTarget(origin)
	local bestData = nil
	local bestDistance = math.huge

	for _, player in ipairs(Players:GetPlayers()) do
		if player ~= LocalPlayer and not isSameTeam(player) then
			local character = player.Character
			local humanoid = character and character:FindFirstChildOfClass("Humanoid")
			local root = character and character:FindFirstChild("HumanoidRootPart")

			if character
				and humanoid
				and humanoid.Health > 0
				and root
				and not character:FindFirstChild("SpawnProtection")
			then
				local distance = (root.Position - origin).Magnitude

				if distance <= RANGE and distance < bestDistance then
					for _, aimPart in ipairs(getAimParts(character)) do
						if hasClearShot(origin, character, aimPart) then
							bestDistance = distance
							bestData = {
								Player = player,
								Character = character,
								Humanoid = humanoid,
								AimPart = aimPart,
								AimPosition = aimPart.Position,
								Distance = distance,
							}
							break
						end
					end
				end
			end
		end
	end

	return bestData
end

local function updateTargetDisplay(data)
	if not data then
		TargetName.Text = "NONE"
		TargetInfo.Text = "Distance: --  •  Aim: --"
		return
	end

	local player = data.Player
	local displayName = player.DisplayName

	if displayName ~= player.Name then
		TargetName.Text = string.format("%s  (@%s)", displayName, player.Name)
	else
		TargetName.Text = player.Name
	end

	TargetInfo.Text = string.format(
		"Distance: %.1f studs  •  Aim: %s",
		data.Distance,
		data.AimPart.Name
	)
end

local function fireAt(data, origin)
	if not data or not data.AimPart:IsDescendantOf(data.Character) then
		return false
	end

	if data.Humanoid.Health <= 0 or data.Character:FindFirstChild("SpawnProtection") then
		return false
	end

	-- Re-check visibility immediately before sending the shot.
	if not hasClearShot(origin, data.Character, data.AimPart) then
		return false
	end

	local aimPosition = data.AimPart.Position
	local offset = aimPosition - origin

	if offset.Magnitude <= 0.01 or offset.Magnitude > RANGE then
		return false
	end

	local direction = offset.Unit
	local isHeadshot = data.AimPart.Name == "Head" or data.AimPart.Name == "HeadHitbox"

	ActionRemote:FireServer({
		origin = origin,
		direction = direction,
		hitPosition = aimPosition,
		hitInstance = data.AimPart,
		hitHumanoid = data.Humanoid,
		IsHeadshot = isHeadshot,
	})

	local camera = getCurrentCamera()
	local viewmodel = camera and camera:FindFirstChild("Viewmodel")
	local weaponAttachment = viewmodel and viewmodel:FindFirstChild("WeaponAttachment")
	local muzzle = weaponAttachment and weaponAttachment:FindFirstChild("MuzzleAttachment")

	if ReplicateFakeBullet and muzzle then
		ReplicateFakeBullet:FireServer(muzzle.WorldCFrame, direction)
	end

	if CharacterMuzzleFlash then
		CharacterMuzzleFlash:FireServer()
	end

	return true
end

local function scanAndShoot()
	local now = os.clock()

	if now - State.LastScanAt < SCAN_INTERVAL then
		return
	end

	State.LastScanAt = now

	if not State.AutoShoot then
		State.Target = nil
		State.TargetData = nil
		updateTargetDisplay(nil)
		setStatus("DISABLED", Theme.Red)
		return
	end

	local _, weaponError = getEquippedWeapon()

	if weaponError then
		State.Target = nil
		State.TargetData = nil
		updateTargetDisplay(nil)
		setStatus(weaponError, Theme.Orange)
		return
	end

	local camera = getCurrentCamera()
	local origin = camera.CFrame.Position
	local targetData = findNearestVisibleTarget(origin)

	State.TargetData = targetData
	State.Target = targetData and targetData.Player or nil
	updateTargetDisplay(targetData)

	if not targetData then
		setStatus("NO VISIBLE TARGET", Theme.Orange)
		return
	end

	local cooldownLeft = RELOAD_DURATION - (now - State.LastShotAt)

	if cooldownLeft > 0 then
		setStatus(string.format("RELOADING  %.2fs", cooldownLeft), Theme.Blue)
		return
	end

	if fireAt(targetData, origin) then
		State.LastShotAt = now
		setStatus("SHOT SENT  •  SERVER CHECKING", Theme.Green)
	else
		setStatus("TARGET MOVED BEHIND COVER", Theme.Orange)
	end
end

