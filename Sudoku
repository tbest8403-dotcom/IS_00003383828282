local function GetBoardPosition(Board)
	local Success, BoardPivot = pcall(function()
		return Board:GetPivot()
	end)

	if Success then
		return BoardPivot.Position
	end

	local BoardPart = Board:FindFirstChildWhichIsA("BasePart", true)
	return BoardPart and BoardPart.Position or nil
end

local function GetBoardFrame(Board)
	local SurfaceGui = Board:FindFirstChild("SurfaceGui")
	return SurfaceGui and SurfaceGui:FindFirstChild("Frame") or nil
end

local function GetNearestBoard()
	local Character = LocalPlayer.Character
	local RootPart = Character and Character:FindFirstChild("HumanoidRootPart")

	if not RootPart then
		return nil
	end

	local NearestBoard
	local NearestDistance = math.huge

	for _, Board in ipairs(PlacedBoards:GetChildren()) do
		if GetBoardFrame(Board) then
			local BoardPosition = GetBoardPosition(Board)

			if BoardPosition then
				local Distance = (RootPart.Position - BoardPosition).Magnitude

				if Distance < NearestDistance then
					NearestDistance = Distance
					NearestBoard = Board
				end
			end
		end
	end

	return NearestBoard, NearestDistance
end

local function ReadBoard(Board)
	local BoardFrame = GetBoardFrame(Board)
	if not BoardFrame then
		return nil, nil, "The board's SurfaceGui.Frame is missing"
	end

	-- Cell names are internal IDs in this game and are not guaranteed to be
	-- row-major. Read them by their rendered positions instead.
	task.wait()

	local CandidateCells = {}

	for _, Child in ipairs(BoardFrame:GetChildren()) do
		if Child:IsA("TextButton") and Child.Name ~= "ClueTemplate" and Child:FindFirstChild("ClueValue") then
			table.insert(CandidateCells, Child)
		end
	end

	if #CandidateCells ~= 81 then
		return nil, nil, "Expected 81 squares, found " .. #CandidateCells
	end

	local MinimumX = math.huge
	local MaximumX = -math.huge
	local MinimumY = math.huge
	local MaximumY = -math.huge

	for _, Cell in ipairs(CandidateCells) do
		local Position = Cell.AbsolutePosition
		MinimumX = math.min(MinimumX, Position.X)
		MaximumX = math.max(MaximumX, Position.X)
		MinimumY = math.min(MinimumY, Position.Y)
		MaximumY = math.max(MaximumY, Position.Y)
	end

	local OrderedCells = table.create(81)
	local HasRenderedPositions = MaximumX - MinimumX > 2 and MaximumY - MinimumY > 2

	if HasRenderedPositions then
		table.sort(CandidateCells, function(First, Second)
			return First.AbsolutePosition.Y < Second.AbsolutePosition.Y
		end)

		for Row = 1, 9 do
			local RowCells = {}

			for Column = 1, 9 do
				table.insert(RowCells, CandidateCells[(Row - 1) * 9 + Column])
			end

			table.sort(RowCells, function(First, Second)
				return First.AbsolutePosition.X < Second.AbsolutePosition.X
			end)

			for Column = 1, 9 do
				OrderedCells[(Row - 1) * 9 + Column] = RowCells[Column]
			end
		end
	else
		table.sort(CandidateCells, function(First, Second)
			if First.LayoutOrder ~= Second.LayoutOrder then
				return First.LayoutOrder < Second.LayoutOrder
			end

			return (tonumber(First.Name) or math.huge) < (tonumber(Second.Name) or math.huge)
		end)

		OrderedCells = CandidateCells
	end

	local Grid = table.create(9)
	local Cells = table.create(81)

	for Row = 1, 9 do
		Grid[Row] = table.create(9, 0)
	end

	for Index = 1, 81 do
		local Cell = OrderedCells[Index]

		local ClueValue = Cell:FindFirstChild("ClueValue")
		if not ClueValue or not (ClueValue:IsA("TextLabel") or ClueValue:IsA("TextButton") or ClueValue:IsA("TextBox")) then
			return nil, nil, "Cell " .. Cell.Name .. " has no readable ClueValue"
		end

		local Text = ClueValue.Text
		local Value = Text:match("^%s*([1-9])%s*$")
		local Row = math.floor((Index - 1) / 9) + 1
		local Column = ((Index - 1) % 9) + 1

		Grid[Row][Column] = Value and tonumber(Value) or 0
		Cells[Index] = Cell
	end

	return Grid, Cells
end

local function CanPlace(Grid, Row, Column, Value)
	for Index = 1, 9 do
		if Grid[Row][Index] == Value or Grid[Index][Column] == Value then
			return false
		end
	end

	local BoxRow = math.floor((Row - 1) / 3) * 3 + 1
	local BoxColumn = math.floor((Column - 1) / 3) * 3 + 1

	for RowOffset = 0, 2 do
		for ColumnOffset = 0, 2 do
			if Grid[BoxRow + RowOffset][BoxColumn + ColumnOffset] == Value then
				return false
			end
		end
	end

	return true
end

local function IsGridValid(Grid)
	for Row = 1, 9 do
		for Column = 1, 9 do
			local Value = Grid[Row][Column]

			if Value ~= 0 then
				Grid[Row][Column] = 0
				local Valid = CanPlace(Grid, Row, Column, Value)
				Grid[Row][Column] = Value

				if not Valid then
					return false
				end
			end
		end
	end

	return true
end

local function GetCandidates(Grid, Row, Column)
	local Candidates = {}

	for Value = 1, 9 do
		if CanPlace(Grid, Row, Column, Value) then
			table.insert(Candidates, Value)
		end
	end

	return Candidates
end

local function SolveGrid(Grid)
	local BestRow
	local BestColumn
	local BestCandidates

	for Row = 1, 9 do
		for Column = 1, 9 do
			if Grid[Row][Column] == 0 then
				local Candidates = GetCandidates(Grid, Row, Column)

				if #Candidates == 0 then
					return false
				end

				if not BestCandidates or #Candidates < #BestCandidates then
					BestRow = Row
					BestColumn = Column
					BestCandidates = Candidates

					if #Candidates == 1 then
						break
					end
				end
			end
		end

		if BestCandidates and #BestCandidates == 1 then
			break
		end
	end

	if not BestRow then
		return true
	end

	for _, Value in ipairs(BestCandidates) do
		Grid[BestRow][BestColumn] = Value

		if SolveGrid(Grid) then
			return true
		end
	end

	Grid[BestRow][BestColumn] = 0
	return false
end

local Busy = false

local function SetBusy(IsBusy, Action)
	Busy = IsBusy
	ScanButton.Active = not IsBusy
	AutoFinishButton.Active = not IsBusy
	ScanButton.BackgroundColor3 = IsBusy and Color3.fromRGB(40, 40, 46) or Color3.fromRGB(48, 48, 57)
	AutoFinishButton.BackgroundColor3 = IsBusy and Color3.fromRGB(65, 65, 72) or Color3.fromRGB(78, 105, 255)
	ScanButton.Text = IsBusy and Action == "Scan" and "SCANNING..." or "SCAN ANSWERS"
	AutoFinishButton.Text = IsBusy and Action == "Finish" and "FINISHING..." or "AUTO-FINISH"
end

local function ClearAnswerGrid()
	for Index = 1, 81 do
		AnswerCells[Index].Text = ""
		AnswerCells[Index].TextColor3 = Color3.fromRGB(225, 225, 232)
	end
end

local function SetError(Message)
	StatusLabel.Text = Message
	StatusLabel.TextColor3 = Color3.fromRGB(255, 125, 125)
end

local function ScanNearestBoard()
	ClearAnswerGrid()
	StatusLabel.TextColor3 = Color3.fromRGB(159, 159, 169)

	local Board, Distance = GetNearestBoard()
	if not Board then
		SetError("No placed board was found")
		return nil
	end

	StatusLabel.Text = string.format("Reading nearest board (%.1f studs)...", Distance)

	local Grid, Cells, ReadError = ReadBoard(Board)
	if not Grid then
		SetError(ReadError)
		return nil
	end

	if not IsGridValid(Grid) then
		SetError("Existing numbers conflict with each other")
		return nil
	end

	local BlankIndices = {}
	local BlankLookup = {}

	for Index = 1, 81 do
		local Row = math.floor((Index - 1) / 9) + 1
		local Column = ((Index - 1) % 9) + 1

		if Grid[Row][Column] == 0 then
			table.insert(BlankIndices, Index)
			BlankLookup[Index] = true
		end
	end

	StatusLabel.Text = "Calculating solution..."
	if not SolveGrid(Grid) then
		SetError("This board has no valid solution")
		return nil
	end

	for Index = 1, 81 do
		local Row = math.floor((Index - 1) / 9) + 1
		local Column = ((Index - 1) % 9) + 1
		AnswerCells[Index].Text = tostring(Grid[Row][Column])
		AnswerCells[Index].TextColor3 = BlankLookup[Index]
			and Color3.fromRGB(125, 165, 255)
			or Color3.fromRGB(238, 238, 242)
	end

	StatusLabel.TextColor3 = Color3.fromRGB(130, 235, 160)
	StatusLabel.Text = #BlankIndices == 0
		and "Board is already complete"
		or string.format("Answers found — %d blank cells", #BlankIndices)

	return {
		Board = Board,
		Grid = Grid,
		Cells = Cells,
		BlankIndices = BlankIndices,
	}
end

ScanButton.MouseButton1Click:Connect(function()
	if Busy then
		return
	end

	SetBusy(true, "Scan")
	ScanNearestBoard()
	SetBusy(false)
end)

AutoFinishButton.MouseButton1Click:Connect(function()
	if Busy then
		return
	end

	SetBusy(true, "Finish")
	local Scan = ScanNearestBoard()

	if not Scan then
		SetBusy(false)
		return
	end

	if #Scan.BlankIndices == 0 then
		SetBusy(false)
		return
	end

	for Completed, Index in ipairs(Scan.BlankIndices) do
		local Board = Scan.Board

		if not Board.Parent then
			SetError("The board was removed")
			SetBusy(false)
			return
		end

		local Row = math.floor((Index - 1) / 9) + 1
		local Column = ((Index - 1) % 9) + 1
		StatusLabel.TextColor3 = Color3.fromRGB(159, 159, 169)
		StatusLabel.Text = string.format("Filling board... %d/%d", Completed, #Scan.BlankIndices)
		PlaceNumberRemote:FireServer(Scan.Cells[Index], Scan.Grid[Row][Column])
		task.wait(SubmitDelay)
	end

	StatusLabel.Text = "Board solution submitted"
	StatusLabel.TextColor3 = Color3.fromRGB(130, 235, 160)
	SetBusy(false)
end)
