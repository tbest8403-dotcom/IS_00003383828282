SliderKnob.InputBegan:Connect(BeginSlider)

TitleBar.InputBegan:Connect(function(Input)
	if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then
		Dragging = true
		DragStart = Input.Position
		StartPosition = MainFrame.Position

		Input.Changed:Connect(function()
			if Input.UserInputState == Enum.UserInputState.End then
				Dragging = false
			end
		end)
	end
end)

TitleBar.InputChanged:Connect(function(Input)
	if Input.UserInputType == Enum.UserInputType.MouseMovement or Input.UserInputType == Enum.UserInputType.Touch then
		DragInput = Input
	end
end)

UserInputService.InputChanged:Connect(function(Input)
	if Dragging and Input == DragInput then
		UpdateDrag(Input)
	end

	if Input.UserInputType == Enum.UserInputType.Touch then
		LastTouchPosition = Vector2.new(Input.Position.X, Input.Position.Y)
	end

	if SliderDragging and (Input == SliderInput or Input.UserInputType == Enum.UserInputType.MouseMovement) then
		UpdatePrediction(Input.Position.X)
	end
end)

UserInputService.InputEnded:Connect(function(Input)
	if Input == SliderInput or Input.UserInputType == Enum.UserInputType.MouseButton1 then
		SliderDragging = false
		SliderInput = nil
	end
end)

