UserInputService.InputBegan:Connect(function(Input, GameProcessed)
	if GameProcessed then
		return
	end

	if WaitingForSpectatorHotkey and Input.UserInputType == Enum.UserInputType.Keyboard then
		WaitingForSpectatorHotkey = false
		HotkeyButton.BackgroundColor3 = Color3.fromRGB(48, 48, 57)

		if Input.KeyCode ~= Enum.KeyCode.Escape and Input.KeyCode ~= Enum.KeyCode.Unknown then
			SpectatorHotkey = Input.KeyCode
		end

		HotkeyButton.Text = "HOTKEY: " .. SpectatorHotkey.Name
		return
	end

	if Input.UserInputType == Enum.UserInputType.Keyboard and Input.KeyCode == SpectatorHotkey then
		if SpectatorEnabled then
			DisableSpectator()
		else
			EnableSpectator()
		end
		return
	end

	if Input.UserInputType == Enum.UserInputType.MouseButton1 then
		FireAtPointer(Vector2.new(Input.Position.X, Input.Position.Y))
	end
end)

UserInputService.TouchTapInWorld:Connect(function(Position, GameProcessed)
	if GameProcessed then
		return
	end

	LastTouchPosition = Position
	FireAtPointer(Position)
end)

RenderConnection = RunService.RenderStepped:Connect(function(DeltaTime)
	UpdateSpectator(DeltaTime)

	RoleRefreshAccumulator += DeltaTime

	if RoleRefreshAccumulator >= 0.2 then
		RoleRefreshAccumulator = 0
		RefreshRoleVisuals()
	end

	if not TargetingEnabled then
		TargetCircle.Visible = false
		UpdateTrackingDisplay(nil, nil, false, false)
		return
	end

	local PointerPosition = GetPointerPosition()
	TargetCircle.Visible = true
	TargetCircle.Position = UDim2.fromOffset(PointerPosition.X, PointerPosition.Y)

	local Gun, _, OriginAttachment = GetEquippedGun()
	local OriginPosition = OriginAttachment and OriginAttachment.WorldPosition or CurrentCamera.CFrame.Position

	if Gun then
		SetManualActivation(Gun, true)
	end

	local HoveredPlayer, HoveredAimPart = FindHoveredPlayerNearPointer(PointerPosition)
	local HoveredCharacter = HoveredPlayer and HoveredPlayer.Character
	local HoveredPredictedPosition = HoveredCharacter and HoveredAimPart
		and GetPredictedAimPosition(HoveredCharacter, HoveredAimPart)
	local HoveredClearShot = HoveredPredictedPosition
		and HasClearShot(OriginPosition, HoveredCharacter, HoveredPredictedPosition)
		or false
	local TargetPlayer, AimPart = FindTargetNearPointer(PointerPosition, OriginPosition)
	SetCurrentTarget(TargetPlayer, AimPart)
	UpdateTrackingDisplay(HoveredPlayer, HoveredAimPart, Gun ~= nil, HoveredClearShot)

	if HoveredPlayer then
		CircleTargetLabel.Text = HoveredPlayer.DisplayName
		if not Gun then
			TargetCircleStroke.Color = Color3.fromRGB(205, 135, 55)
			TargetCircleStroke.Thickness = 2
			CircleTargetLabel.TextColor3 = Color3.fromRGB(245, 180, 90)
			StatusLabel.Text = "Hovering " .. HoveredPlayer.DisplayName .. " • equip gun"
			StatusLabel.TextColor3 = Color3.fromRGB(255, 170, 105)
		elseif HoveredClearShot and TargetPlayer == HoveredPlayer then
			TargetCircleStroke.Color = Color3.fromRGB(255, 25, 35)
			TargetCircleStroke.Thickness = 3
			CircleTargetLabel.TextColor3 = Color3.fromRGB(255, 70, 78)
			StatusLabel.Text = "Hovering " .. HoveredPlayer.DisplayName .. " • clear shot"
			StatusLabel.TextColor3 = Color3.fromRGB(130, 235, 160)
		else
			TargetCircleStroke.Color = Color3.fromRGB(235, 145, 55)
			TargetCircleStroke.Thickness = 3
			CircleTargetLabel.Text = HoveredPlayer.DisplayName .. " • WALL"
			CircleTargetLabel.TextColor3 = Color3.fromRGB(255, 180, 90)
			StatusLabel.Text = "Hovering " .. HoveredPlayer.DisplayName .. " • blocked by wall"
			StatusLabel.TextColor3 = Color3.fromRGB(255, 170, 105)
		end
	elseif TargetPlayer then
		TargetCircleStroke.Color = Color3.fromRGB(255, 25, 35)
		TargetCircleStroke.Thickness = 3
		CircleTargetLabel.Text = TargetPlayer.DisplayName
		CircleTargetLabel.TextColor3 = Color3.fromRGB(255, 70, 78)
	else
		TargetCircleStroke.Color = Color3.fromRGB(205, 45, 55)
		TargetCircleStroke.Thickness = 2
		CircleTargetLabel.Text = Gun and "NO TARGET" or "EQUIP GUN"
		CircleTargetLabel.TextColor3 = Color3.fromRGB(210, 85, 90)
	end
end)

