local function GetEquippedGun()
	local Character = LocalPlayer.Character
	local Gun = Character and Character:FindFirstChild("Gun")
	local Shoot = Gun and Gun:FindFirstChild("Shoot")
	local RootPart = Character and Character:FindFirstChild("HumanoidRootPart")
	local OriginAttachment = RootPart and RootPart:FindFirstChild("GunRaycastAttachment")

	if Gun and Gun:IsA("Tool") and Shoot and Shoot:IsA("RemoteEvent") and OriginAttachment and OriginAttachment:IsA("Attachment") then
		return Gun, Shoot, OriginAttachment
	end

	return nil
end

local function SetManualActivation(Gun, ManualOnly)
	if not Gun then
		return
	end

	if OriginalManualActivation[Gun] == nil then
		OriginalManualActivation[Gun] = Gun.ManualActivationOnly
	end

	Gun.ManualActivationOnly = ManualOnly
end

local function RestoreManualActivation()
	for Gun, OriginalValue in pairs(OriginalManualActivation) do
		if Gun.Parent then
			Gun.ManualActivationOnly = OriginalValue
		end
	end

	table.clear(OriginalManualActivation)
end

local function HasNamedTool(Container, ToolName)
	if not Container then
		return false
	end

	for _, Child in ipairs(Container:GetChildren()) do
		if Child:IsA("Tool") and string.lower(Child.Name) == string.lower(ToolName) then
			return true
		end
	end

	return false
end

local function ClearRoleHighlight(Player)
	local Highlight = RoleHighlights[Player]

	if Highlight then
		Highlight:Destroy()
		RoleHighlights[Player] = nil
	end
end

local function ClearAllRoleHighlights()
	for _, Highlight in pairs(RoleHighlights) do
		if Highlight then
			Highlight:Destroy()
		end
	end

	table.clear(RoleHighlights)
end

local function UpdateRoleVisual(Player)
	if not RoleVisualsEnabled or Player == LocalPlayer then
		ClearRoleHighlight(Player)
		return
	end

	local Character = Player.Character
	local Humanoid = Character and Character:FindFirstChildOfClass("Humanoid")
	local Backpack = Player:FindFirstChildOfClass("Backpack") or Player:FindFirstChild("Backpack")

	if not Character or not Humanoid or Humanoid.Health <= 0 then
		ClearRoleHighlight(Player)
		return
	end

	local HasKnife = HasNamedTool(Character, "Knife") or HasNamedTool(Backpack, "Knife")
	local HasGun = HasNamedTool(Character, "Gun") or HasNamedTool(Backpack, "Gun")
	local OutlineColor

	if HasKnife then
		OutlineColor = Color3.fromRGB(255, 45, 55)
	elseif HasGun then
		OutlineColor = Color3.fromRGB(55, 135, 255)
	else
		-- Regular players keep the neutral visual. Murderer and sheriff
		-- are detected first so this never replaces their role colors.
		OutlineColor = InnocentVisualColor
	end

	local Highlight = RoleHighlights[Player]

	if Highlight and (not Highlight.Parent or Highlight.Adornee ~= Character) then
		ClearRoleHighlight(Player)
		Highlight = nil
	end

	if not Highlight then
		Highlight = Instance.new("Highlight")
		Highlight.Name = "_StaffRoleHighlight"
		Highlight.Adornee = Character
		Highlight.FillTransparency = 1
		Highlight.OutlineTransparency = 0
		Highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
		Highlight.Parent = Character
		RoleHighlights[Player] = Highlight
	end

	Highlight.OutlineColor = OutlineColor

	if CurrentTargetPlayer == Player and CurrentHighlight then
		CurrentHighlight:Destroy()
		CurrentHighlight = nil
	end
end

local function RefreshRoleVisuals()
	if not RoleVisualsEnabled then
		ClearAllRoleHighlights()
		return
	end

	local ActivePlayers = {}

	for _, Player in ipairs(Players:GetPlayers()) do
		ActivePlayers[Player] = true
		UpdateRoleVisual(Player)
	end

	for Player in pairs(RoleHighlights) do
		if not ActivePlayers[Player] then
			ClearRoleHighlight(Player)
		end
	end
end

local function HasClearShot(OriginPosition, TargetCharacter, TargetPosition)
	local Character = LocalPlayer.Character
	local RaycastParameters = RaycastParams.new()
	RaycastParameters.FilterType = Enum.RaycastFilterType.Exclude
	RaycastParameters.FilterDescendantsInstances = Character and { Character } or {}
	RaycastParameters.IgnoreWater = true

	local Result = workspace:Raycast(OriginPosition, TargetPosition - OriginPosition, RaycastParameters)
	return Result == nil or Result.Instance:IsDescendantOf(TargetCharacter)
end

local function ClampVectorMagnitude(Value, MaximumMagnitude)
	local Magnitude = Value.Magnitude
	if Magnitude > MaximumMagnitude and Magnitude > 0 then
		return Value.Unit * MaximumMagnitude
	end
	return Value
end

local function PushPredictionHistory(History, Value)
	table.insert(History, Value)
	if #History > PredictionHistoryLimit then
		table.remove(History, 1)
	end
end

local function GetHistoryAverage(History)
	if #History == 0 then
		return nil, nil
	end

	local Sum = 0
	for _, Value in ipairs(History) do
		Sum += Value
	end

	local Average = Sum / #History
	local Variance = 0
	for _, Value in ipairs(History) do
		Variance += (Value - Average) ^ 2
	end

	return Average, math.sqrt(Variance / #History)
end

local function IsCharacterAirborne(Humanoid)
	local State = Humanoid:GetState()
	return Humanoid.FloorMaterial == Enum.Material.Air
		or State == Enum.HumanoidStateType.Jumping
		or State == Enum.HumanoidStateType.Freefall
		or State == Enum.HumanoidStateType.FallingDown
end

local function GetPredictionMovementState(Humanoid, HorizontalSpeed, VerticalVelocity, Airborne)
	if Airborne then
		local HorizontalName = HorizontalSpeed >= PredictionRunSpeed and "RunJump" or "Jump"
		if VerticalVelocity > 1.25 then
			return HorizontalName .. "Rising"
		elseif VerticalVelocity < -1.25 then
			return HorizontalName .. "Falling"
		end
		return HorizontalName .. "Apex"
	end

	if HorizontalSpeed <= PredictionIdleSpeed and Humanoid.MoveDirection.Magnitude <= 0.04 then
		return "Idle"
	elseif HorizontalSpeed >= PredictionRunSpeed then
		return "Run"
	end
	return "Walk"
end

local function CreatePredictionTracker(TargetCharacter, Humanoid, RootPart, Now)
	local RawVelocity = RootPart.AssemblyLinearVelocity
	local HorizontalVelocity = ClampVectorMagnitude(Vector3.new(RawVelocity.X, 0, RawVelocity.Z), MaximumHorizontalVelocity)
	local Airborne = IsCharacterAirborne(Humanoid)

	local Tracker = {
		LastUpdate = Now,
		LastPosition = RootPart.Position,
		SmoothedHorizontalVelocity = HorizontalVelocity,
		HorizontalAcceleration = Vector3.zero,
		VerticalVelocity = math.clamp(RawVelocity.Y, -MaximumVerticalVelocity, MaximumVerticalVelocity),
		LastDirection = HorizontalVelocity.Magnitude > 1 and HorizontalVelocity.Unit or Vector3.zero,
		Airborne = Airborne,
		MovementState = GetPredictionMovementState(Humanoid, HorizontalVelocity.Magnitude, RawVelocity.Y, Airborne),
		StableDirectionTime = 0,
		LastFlipAt = nil,
		FlipIntervals = {},
		StrafeScore = 0,
		LastTakeoffAt = nil,
		LastLandingAt = nil,
		JumpIntervals = {},
		TakeoffVelocities = {},
	}

	PredictionTrackers[TargetCharacter] = Tracker
	return Tracker
end

local function UpdatePredictionTracker(TargetCharacter, Humanoid, RootPart)
	local Now = os.clock()
	local Tracker = PredictionTrackers[TargetCharacter]
	if not Tracker then
		return CreatePredictionTracker(TargetCharacter, Humanoid, RootPart, Now)
	end

	local DeltaTime = Now - Tracker.LastUpdate
	if DeltaTime < 1 / 240 then
		return Tracker
	end

	local RawVelocity = RootPart.AssemblyLinearVelocity
	local PositionDelta = (RootPart.Position - Tracker.LastPosition).Magnitude
	local ExpectedTravel = math.max(0, RawVelocity.Magnitude * DeltaTime)
	if DeltaTime > 0.35 or PositionDelta > math.max(PredictionTeleportDistance, ExpectedTravel * 2.5 + 5) then
		return CreatePredictionTracker(TargetCharacter, Humanoid, RootPart, Now)
	end

	local RawHorizontalVelocity = ClampVectorMagnitude(
		Vector3.new(RawVelocity.X, 0, RawVelocity.Z),
		MaximumHorizontalVelocity
	)
	local HorizontalSpeed = RawHorizontalVelocity.Magnitude
	local CurrentDirection = HorizontalSpeed > 1 and RawHorizontalVelocity.Unit or Vector3.zero
	local PreviousHorizontalVelocity = Tracker.SmoothedHorizontalVelocity
	local DirectionDot = 1

	if CurrentDirection.Magnitude > 0 and Tracker.LastDirection.Magnitude > 0 then
		DirectionDot = CurrentDirection:Dot(Tracker.LastDirection)
	end

	local ReversedDirection = HorizontalSpeed > 3
		and Tracker.LastDirection.Magnitude > 0
		and DirectionDot < -0.35
	local SharpDirectionChange = HorizontalSpeed > 3
		and Tracker.LastDirection.Magnitude > 0
		and DirectionDot < 0.20

	Tracker.StrafeScore = math.max(0, Tracker.StrafeScore - DeltaTime * 0.9)

	if ReversedDirection then
		if Tracker.LastFlipAt then
			local FlipInterval = Now - Tracker.LastFlipAt
			if FlipInterval >= 0.08 and FlipInterval <= 1.5 then
				PushPredictionHistory(Tracker.FlipIntervals, FlipInterval)
			end
		end
		Tracker.LastFlipAt = Now
		Tracker.StrafeScore = math.min(4, Tracker.StrafeScore + 1.25)
		Tracker.StableDirectionTime = 0
	elseif SharpDirectionChange then
		Tracker.StableDirectionTime = 0
	else
		Tracker.StableDirectionTime += DeltaTime
	end

	local SmoothingAlpha = 1 - math.exp(-PredictionVelocitySmoothing * DeltaTime)
	if SharpDirectionChange then
		-- Never drag velocity from the old direction into a new left-right strafe.
		Tracker.SmoothedHorizontalVelocity = RawHorizontalVelocity
		Tracker.HorizontalAcceleration = Vector3.zero
	else
		Tracker.SmoothedHorizontalVelocity = PreviousHorizontalVelocity:Lerp(RawHorizontalVelocity, SmoothingAlpha)
		local MeasuredAcceleration = (Tracker.SmoothedHorizontalVelocity - PreviousHorizontalVelocity) / DeltaTime
		Tracker.HorizontalAcceleration = ClampVectorMagnitude(MeasuredAcceleration, PredictionAccelerationLimit)
	end

	if HorizontalSpeed <= PredictionIdleSpeed then
		local IdleAlpha = 1 - math.exp(-42 * DeltaTime)
		Tracker.SmoothedHorizontalVelocity = Tracker.SmoothedHorizontalVelocity:Lerp(Vector3.zero, IdleAlpha)
		Tracker.HorizontalAcceleration = Vector3.zero
	end

	local Airborne = IsCharacterAirborne(Humanoid)
	local VerticalVelocity = math.clamp(RawVelocity.Y, -MaximumVerticalVelocity, MaximumVerticalVelocity)

	if Airborne and not Tracker.Airborne and VerticalVelocity > 0.5 then
		if Tracker.LastTakeoffAt then
			local JumpInterval = Now - Tracker.LastTakeoffAt
			if JumpInterval >= 0.20 and JumpInterval <= 3 then
				PushPredictionHistory(Tracker.JumpIntervals, JumpInterval)
			end
		end
		Tracker.LastTakeoffAt = Now
		PushPredictionHistory(Tracker.TakeoffVelocities, VerticalVelocity)
	elseif not Airborne and Tracker.Airborne then
		Tracker.LastLandingAt = Now
	end

	Tracker.LastUpdate = Now
	Tracker.LastPosition = RootPart.Position
	Tracker.LastDirection = CurrentDirection.Magnitude > 0 and CurrentDirection or Tracker.LastDirection
	Tracker.VerticalVelocity = VerticalVelocity
	Tracker.Airborne = Airborne
	Tracker.MovementState = GetPredictionMovementState(Humanoid, HorizontalSpeed, VerticalVelocity, Airborne)
	return Tracker
end

local function GetStrafeAwareHorizontalDisplacement(Tracker, PredictionDuration)
	if Tracker.MovementState == "Idle" then
		return Vector3.zero
	end

	local Velocity = Tracker.SmoothedHorizontalVelocity
	local Acceleration = Tracker.HorizontalAcceleration
	if Velocity.Magnitude <= PredictionIdleSpeed then
		return Vector3.zero
	end

	local AverageFlipInterval, FlipDeviation = GetHistoryAverage(Tracker.FlipIntervals)
	local HasReliableStrafeCycle = Tracker.StrafeScore >= 1.5
		and AverageFlipInterval
		and #Tracker.FlipIntervals >= 2
		and FlipDeviation <= AverageFlipInterval * 0.42

	if HasReliableStrafeCycle and Tracker.LastFlipAt then
		local Displacement = Vector3.zero
		local RemainingTime = PredictionDuration
		local TimeSinceFlip = os.clock() - Tracker.LastFlipAt
		local TimeUntilFlip = math.max(0.01, AverageFlipInterval - TimeSinceFlip)
		local SegmentVelocity = Velocity
		local SegmentCount = 0

		while RemainingTime > 0 and SegmentCount < 4 do
			SegmentCount += 1
			local SegmentTime = math.min(RemainingTime, TimeUntilFlip)
			Displacement += SegmentVelocity * SegmentTime
			RemainingTime -= SegmentTime
			if RemainingTime > 0 then
				SegmentVelocity = -SegmentVelocity
				TimeUntilFlip = AverageFlipInterval
			end
		end

		return Displacement
	end

	-- Acceleration helps with normal starts, but is disabled for irregular strafing.
	local AccelerationInfluence = Tracker.StrafeScore < 0.75
		and math.clamp(Tracker.StableDirectionTime / 0.12, 0, 1)
		or 0
	local Displacement = Velocity * PredictionDuration
		+ 0.5 * Acceleration * PredictionDuration * PredictionDuration * AccelerationInfluence

	if Tracker.StrafeScore >= 1.5 and not HasReliableStrafeCycle then
		-- Their next reversal is unpredictable, so reduce only the uncertain part of the lead.
		local UncertaintyScale = math.clamp(1 - Tracker.StrafeScore * 0.09, 0.68, 0.92)
		Displacement *= UncertaintyScale
	end

	return Displacement
end

local function ResolveHorizontalCollision(TargetCharacter, RootPart, HorizontalDisplacement)
	if HorizontalDisplacement.Magnitude <= 0.01 then
		return HorizontalDisplacement
	end

	local RaycastParameters = RaycastParams.new()
	RaycastParameters.FilterType = Enum.RaycastFilterType.Exclude
	RaycastParameters.FilterDescendantsInstances = LocalPlayer.Character
		and { TargetCharacter, LocalPlayer.Character }
		or { TargetCharacter }
	RaycastParameters.IgnoreWater = true

	local Result = workspace:Raycast(RootPart.Position, HorizontalDisplacement, RaycastParameters)
	if not Result then
		return HorizontalDisplacement
	end

	local SafetyDistance = math.max(RootPart.Size.X, RootPart.Size.Z) * 0.5
	local AllowedDistance = math.max(0, Result.Distance - SafetyDistance)
	return HorizontalDisplacement.Unit * AllowedDistance
end

local function GetPredictionFloorRootY(TargetCharacter, Humanoid, RootPart, HorizontalPosition)
	local RootClearance = math.max(1.5, Humanoid.HipHeight + RootPart.Size.Y * 0.5)
	local ProbeOrigin = Vector3.new(HorizontalPosition.X, RootPart.Position.Y + 3, HorizontalPosition.Z)
	local ProbeDistance = 40

	local RaycastParameters = RaycastParams.new()
	RaycastParameters.FilterType = Enum.RaycastFilterType.Exclude
	RaycastParameters.FilterDescendantsInstances = LocalPlayer.Character
		and { TargetCharacter, LocalPlayer.Character }
		or { TargetCharacter }
	RaycastParameters.IgnoreWater = true

	local Result = workspace:Raycast(ProbeOrigin, Vector3.new(0, -ProbeDistance, 0), RaycastParameters)
	if Result and Result.Normal.Y >= 0.45 then
		return Result.Position.Y + RootClearance
	end
	return nil
end

local function GetJumpAwareVerticalDisplacement(TargetCharacter, Humanoid, RootPart, Tracker, HorizontalPosition, PredictionDuration)
	local Gravity = workspace.Gravity
	local FloorRootY = GetPredictionFloorRootY(TargetCharacter, Humanoid, RootPart, HorizontalPosition)
	local AverageJumpInterval, JumpIntervalDeviation = GetHistoryAverage(Tracker.JumpIntervals)
	local AverageTakeoffVelocity = GetHistoryAverage(Tracker.TakeoffVelocities)
	local HasReliableJumpCycle = AverageJumpInterval
		and AverageTakeoffVelocity
		and AverageTakeoffVelocity > 5
		and #Tracker.JumpIntervals >= 2
		and JumpIntervalDeviation <= AverageJumpInterval * 0.30

	local function GetJumpArc(Time)
		return AverageTakeoffVelocity * Time - 0.5 * Gravity * Time * Time
	end

	if Tracker.Airborne then
		local BallisticDisplacement = Tracker.VerticalVelocity * PredictionDuration
			- 0.5 * Gravity * PredictionDuration * PredictionDuration

		if not FloorRootY or Gravity <= 0 then
			return BallisticDisplacement
		end

		local HeightAboveFloor = math.max(0, RootPart.Position.Y - FloorRootY)
		local Discriminant = Tracker.VerticalVelocity * Tracker.VerticalVelocity + 2 * Gravity * HeightAboveFloor
		local LandingTime = (Tracker.VerticalVelocity + math.sqrt(math.max(0, Discriminant))) / Gravity

		if LandingTime >= 0 and LandingTime <= PredictionDuration then
			if HasReliableJumpCycle and Tracker.LastTakeoffAt then
				local ProjectedCycleLength = os.clock() - Tracker.LastTakeoffAt + LandingTime
				local CycleTolerance = math.max(0.10, AverageJumpInterval * 0.25)
				if math.abs(ProjectedCycleLength - AverageJumpInterval) <= CycleTolerance then
					local RemainingJumpTime = PredictionDuration - LandingTime
					return (FloorRootY - RootPart.Position.Y) + GetJumpArc(RemainingJumpTime)
				end
			end

			return FloorRootY - RootPart.Position.Y
		end

		return BallisticDisplacement
	end

	-- Covers the very short grounded frame between repeated jump-spam takeoffs.
	if HasReliableJumpCycle and Tracker.LastTakeoffAt and Tracker.LastLandingAt then
		local TimeSinceTakeoff = os.clock() - Tracker.LastTakeoffAt
		local TimeUntilNextTakeoff = AverageJumpInterval - TimeSinceTakeoff
		if TimeUntilNextTakeoff >= 0
			and TimeUntilNextTakeoff <= PredictionDuration
			and os.clock() - Tracker.LastLandingAt <= 0.18 then
			local RemainingJumpTime = PredictionDuration - TimeUntilNextTakeoff
			return GetJumpArc(RemainingJumpTime)
		end
	end

	return 0
end

local function GetPredictedAimPosition(TargetCharacter, AimPart)
	local RootPart = TargetCharacter:FindFirstChild("HumanoidRootPart")
	local Humanoid = TargetCharacter:FindFirstChildOfClass("Humanoid")

	if not RootPart or not Humanoid or PredictionTime <= 0 then
		return AimPart.Position
	end

	local Tracker = UpdatePredictionTracker(TargetCharacter, Humanoid, RootPart)
	local AimOffset = AimPart.Position - RootPart.Position
	local HorizontalDisplacement = GetStrafeAwareHorizontalDisplacement(Tracker, PredictionTime)
	HorizontalDisplacement = ResolveHorizontalCollision(TargetCharacter, RootPart, HorizontalDisplacement)

	local HorizontalPosition = RootPart.Position + HorizontalDisplacement
	local VerticalDisplacement = GetJumpAwareVerticalDisplacement(
		TargetCharacter,
		Humanoid,
		RootPart,
		Tracker,
		HorizontalPosition,
		PredictionTime
	)

	local PredictedRootPosition = RootPart.Position
		+ HorizontalDisplacement
		+ Vector3.new(0, VerticalDisplacement, 0)

	return PredictedRootPosition + AimOffset
end

local function GetCharacterScreenDistance(Character, PointerPosition)
	CurrentCamera = workspace.CurrentCamera or CurrentCamera

	local MinimumX = math.huge
	local MinimumY = math.huge
	local MaximumX = -math.huge
	local MaximumY = -math.huge
	local HasPointInFront = false

	for _, BodyPart in ipairs(Character:GetChildren()) do
		if BodyPart:IsA("BasePart") then
			local HalfSize = BodyPart.Size * 0.5

			for X = -1, 1, 2 do
				for Y = -1, 1, 2 do
					for Z = -1, 1, 2 do
						local Corner = BodyPart.CFrame:PointToWorldSpace(Vector3.new(
							HalfSize.X * X,
							HalfSize.Y * Y,
							HalfSize.Z * Z
						))
						local ScreenPoint = CurrentCamera:WorldToScreenPoint(Corner)

						if ScreenPoint.Z > 0 then
							HasPointInFront = true
							MinimumX = math.min(MinimumX, ScreenPoint.X)
							MinimumY = math.min(MinimumY, ScreenPoint.Y)
							MaximumX = math.max(MaximumX, ScreenPoint.X)
							MaximumY = math.max(MaximumY, ScreenPoint.Y)
						end
					end
				end
			end
		end
	end

	if not HasPointInFront then
		return nil
	end

	local ViewportSize = CurrentCamera.ViewportSize
	if MaximumX < 0 or MaximumY < 0 or MinimumX > ViewportSize.X or MinimumY > ViewportSize.Y then
		return nil
	end

	local ClosestPoint = Vector2.new(
		math.clamp(PointerPosition.X, MinimumX, MaximumX),
		math.clamp(PointerPosition.Y, MinimumY, MaximumY)
	)

	return (ClosestPoint - PointerPosition).Magnitude
end

local function FindHoveredPlayerNearPointer(PointerPosition)
	CurrentCamera = workspace.CurrentCamera or CurrentCamera

	local BestPlayer
	local BestAimPart
	local BestScreenDistance = TargetRadius

	for _, Player in ipairs(Players:GetPlayers()) do
		if Player ~= LocalPlayer then
			local Character = Player.Character
			local Humanoid = Character and Character:FindFirstChildOfClass("Humanoid")
			local RootPart = Character and Character:FindFirstChild("HumanoidRootPart")
			local AimPart = Character and (Character:FindFirstChild("Head") or RootPart)

				if Humanoid and Humanoid.Health > 0 and RootPart and AimPart then
					local ScreenDistance = GetCharacterScreenDistance(Character, PointerPosition)

					if ScreenDistance and ScreenDistance <= BestScreenDistance then
						BestPlayer = Player
						BestAimPart = AimPart
						BestScreenDistance = ScreenDistance
					end
				end
			end
		end

	return BestPlayer, BestAimPart, BestScreenDistance
end

local function FindTargetNearPointer(PointerPosition, OriginPosition)
	local HoveredPlayer, AimPart = FindHoveredPlayerNearPointer(PointerPosition)
	local Character = HoveredPlayer and HoveredPlayer.Character
	if not Character or not AimPart then
		return nil, nil
	end

	local PredictedPosition = GetPredictedAimPosition(Character, AimPart)
	if HasClearShot(OriginPosition, Character, PredictedPosition) then
		return HoveredPlayer, AimPart
	end

	return nil, nil
end

local function GetPrettyMovementState(StateName)
	local Names = {
		Idle = "IDLE",
		Walk = "WALKING",
		Run = "RUNNING",
		JumpRising = "JUMP • RISING",
		JumpApex = "JUMP • APEX",
		JumpFalling = "JUMP • FALLING",
		RunJumpRising = "RUN + JUMP • RISING",
		RunJumpApex = "RUN + JUMP • APEX",
		RunJumpFalling = "RUN + JUMP • FALLING",
	}
	return Names[StateName] or string.upper(StateName or "UNKNOWN")
end

local function UpdateTrackingDisplay(HoveredPlayer, AimPart, HasGun, ClearShot)
	CurrentHoveredPlayer = HoveredPlayer
	local Character = HoveredPlayer and HoveredPlayer.Character
	local Humanoid = Character and Character:FindFirstChildOfClass("Humanoid")
	local RootPart = Character and Character:FindFirstChild("HumanoidRootPart")

	if not Character or not Humanoid or not RootPart or not AimPart then
		TrackingPlayerLabel.Text = "Hover the circle over a player"
		TrackingValidity.Text = "NO PLAYER"
		TrackingValidity.TextColor3 = Color3.fromRGB(150, 150, 161)
		TrackingCardStroke.Color = Color3.fromRGB(56, 56, 65)
		TrackingDataLabel.Text = "STATE    --\nSPEED    --        VERTICAL  --\nACCEL    --\nSTRAFE   --\nJUMP     --        LEAD      --"
		return
	end

	local Tracker = UpdatePredictionTracker(Character, Humanoid, RootPart)
	local PredictedPosition = GetPredictedAimPosition(Character, AimPart)
	local PredictionOffset = PredictedPosition - AimPart.Position
	local HorizontalLead = Vector3.new(PredictionOffset.X, 0, PredictionOffset.Z).Magnitude
	local HorizontalSpeed = Tracker.SmoothedHorizontalVelocity.Magnitude
	local AverageFlipInterval, FlipDeviation = GetHistoryAverage(Tracker.FlipIntervals)
	local AverageJumpInterval = GetHistoryAverage(Tracker.JumpIntervals)
	local StrafeText

	if Tracker.StrafeScore >= 1.5 and AverageFlipInterval and #Tracker.FlipIntervals >= 2 then
		if FlipDeviation <= AverageFlipInterval * 0.42 then
			StrafeText = string.format("PATTERN %.2fs  FLIPS %d", AverageFlipInterval, #Tracker.FlipIntervals)
		else
			StrafeText = string.format("IRREGULAR  FLIPS %d", #Tracker.FlipIntervals)
		end
	elseif Tracker.StrafeScore >= 0.75 then
		StrafeText = "DIRECTION REVERSAL"
	else
		StrafeText = "STABLE"
	end

	local JumpText
	if Tracker.Airborne then
		JumpText = Tracker.VerticalVelocity > 1.25 and "RISING"
			or Tracker.VerticalVelocity < -1.25 and "FALLING"
			or "APEX"
	elseif AverageJumpInterval and #Tracker.JumpIntervals >= 2 then
		JumpText = string.format("CYCLE %.2fs", AverageJumpInterval)
	else
		JumpText = "GROUNDED"
	end

	TrackingPlayerLabel.Text = HoveredPlayer.DisplayName .. "  @" .. HoveredPlayer.Name
	if not HasGun then
		TrackingValidity.Text = "EQUIP GUN"
		TrackingValidity.TextColor3 = Color3.fromRGB(255, 174, 95)
		TrackingCardStroke.Color = Color3.fromRGB(125, 91, 44)
	elseif ClearShot then
		TrackingValidity.Text = "CLEAR SHOT"
		TrackingValidity.TextColor3 = Color3.fromRGB(100, 230, 145)
		TrackingCardStroke.Color = Color3.fromRGB(47, 126, 79)
	else
		TrackingValidity.Text = "BLOCKED • WALL"
		TrackingValidity.TextColor3 = Color3.fromRGB(255, 174, 95)
		TrackingCardStroke.Color = Color3.fromRGB(145, 87, 41)
	end

	TrackingDataLabel.Text = string.format(
		"STATE    %s\nSPEED    %6.2f     VERTICAL %+6.2f\nACCEL    %6.2f     STRAFE   %s\nJUMP     %-10s LEAD H %5.2f\nLEAD Y   %+6.2f     DELAY    %.2fs",
		GetPrettyMovementState(Tracker.MovementState),
		HorizontalSpeed,
		Tracker.VerticalVelocity,
		Tracker.HorizontalAcceleration.Magnitude,
		StrafeText,
		JumpText,
		HorizontalLead,
		PredictionOffset.Y,
		PredictionTime
	)
end

local function ClearTargetHighlight()
	if CurrentHighlight then
		CurrentHighlight:Destroy()
		CurrentHighlight = nil
	end
end

local function SetCurrentTarget(Player, AimPart)
	CurrentTargetPlayer = Player
	CurrentTargetPart = AimPart

	local Character = Player and Player.Character
	local HasRoleHighlight = Player and RoleHighlights[Player] ~= nil

	if not Character or HasRoleHighlight then
		ClearTargetHighlight()
		return
	end

	if CurrentHighlight and CurrentHighlight.Adornee == Character then
		return
	end

	ClearTargetHighlight()

	if Character then
		CurrentHighlight = Instance.new("Highlight")
		CurrentHighlight.Name = "_StaffMouseTargetHighlight"
		CurrentHighlight.Adornee = Character
		CurrentHighlight.FillTransparency = 1
		CurrentHighlight.OutlineColor = Color3.fromRGB(255, 45, 55)
		CurrentHighlight.OutlineTransparency = 0.05
		CurrentHighlight.DepthMode = Enum.HighlightDepthMode.Occluded
		CurrentHighlight.Parent = Character
	end
end

local function SetTargetingState(Enabled, StatusText)
	TargetingEnabled = Enabled

	if Enabled then
		ToggleButton.Text = "TARGETING: ON"
		ToggleButton.BackgroundColor3 = Color3.fromRGB(190, 45, 55)
		StatusLabel.Text = StatusText or "Move the circle near a player, then click"
	else
		ToggleButton.Text = "TARGETING: OFF"
		ToggleButton.BackgroundColor3 = Color3.fromRGB(48, 48, 57)
		StatusLabel.Text = StatusText or "Targeting disabled"
		TargetCircle.Visible = false
		SetCurrentTarget(nil, nil)
		RestoreManualActivation()
	end

	StatusLabel.TextColor3 = Color3.fromRGB(160, 160, 170)
end

local function SetSpectatorButtonState(Enabled)
	if Enabled then
		SpectatorButton.Text = "SPECTATOR: ON"
		SpectatorButton.BackgroundColor3 = Color3.fromRGB(125, 70, 205)
	else
		SpectatorButton.Text = "SPECTATOR: OFF"
		SpectatorButton.BackgroundColor3 = Color3.fromRGB(48, 48, 57)
	end
end

local function FindSpectatorAnimation(Character, StateName)
	local Animate = Character and Character:FindFirstChild("Animate")
	if not Animate then
		return nil
	end

	for _, Child in ipairs(Animate:GetChildren()) do
		if string.lower(Child.Name) == string.lower(StateName) then
			return Child:FindFirstChildWhichIsA("Animation", true)
		end
	end

	for _, Descendant in ipairs(Animate:GetDescendants()) do
		if Descendant:IsA("Animation") and string.find(string.lower(Descendant.Name), string.lower(StateName), 1, true) then
			return Descendant
		end
	end

	return nil
end

local function StopSpectatorAnimations()
	for _, Track in pairs(SpectatorAnimationTracks) do
		if Track then
			pcall(function()
				Track:Stop(0.1)
			end)
		end
	end

	table.clear(SpectatorAnimationTracks)
	SpectatorAnimationName = nil
end

local function LoadSpectatorAnimations(RealCharacter, CloneHumanoid)
	StopSpectatorAnimations()

	local Animator = CloneHumanoid:FindFirstChildOfClass("Animator")
	if not Animator then
		Animator = Instance.new("Animator")
		Animator.Parent = CloneHumanoid
	end

	local Configurations = {
		Idle = { Source = "idle", Looped = true, Priority = Enum.AnimationPriority.Idle },
		Walk = { Source = "walk", Looped = true, Priority = Enum.AnimationPriority.Movement },
		Run = { Source = "run", Looped = true, Priority = Enum.AnimationPriority.Movement },
		Jump = { Source = "jump", Looped = false, Priority = Enum.AnimationPriority.Action },
		Fall = { Source = "fall", Looped = true, Priority = Enum.AnimationPriority.Movement },
	}

	for Name, Configuration in pairs(Configurations) do
		local Animation = FindSpectatorAnimation(RealCharacter, Configuration.Source)

		if Animation and Animation.AnimationId ~= "" then
			local Success, Track = pcall(function()
				return Animator:LoadAnimation(Animation)
			end)

			if Success and Track then
				Track.Looped = Configuration.Looped
				Track.Priority = Configuration.Priority
				SpectatorAnimationTracks[Name] = Track
			end
		end
	end
end

local function UpdateSpectatorAnimation(HorizontalSpeed, VerticalDirection)
	local DesiredName

	if VerticalDirection > 0.05 and SpectatorAnimationTracks.Jump then
		DesiredName = "Jump"
	elseif VerticalDirection < -0.05 and SpectatorAnimationTracks.Fall then
		DesiredName = "Fall"
	elseif HorizontalSpeed > 0.05 then
		DesiredName = SpectatorAnimationTracks.Walk and "Walk" or "Run"
	else
		DesiredName = "Idle"
	end

	local DesiredTrack = DesiredName and SpectatorAnimationTracks[DesiredName]
	if not DesiredTrack then
		return
	end

	if SpectatorAnimationName ~= DesiredName then
		for Name, Track in pairs(SpectatorAnimationTracks) do
			if Name ~= DesiredName and Track.IsPlaying then
				Track:Stop(0.12)
			end
		end

		SpectatorAnimationName = DesiredName
		DesiredTrack:Play(0.12)
	elseif not DesiredTrack.IsPlaying then
		DesiredTrack:Play(0.12)
	end

	if DesiredName == "Walk" or DesiredName == "Run" then
		DesiredTrack:AdjustSpeed(math.clamp(SpectatorMoveSpeed / 16, 0.5, 2.5))
	else
		DesiredTrack:AdjustSpeed(1)
	end
end

local function ClearCharacterVelocity(Character)
	if not Character then
		return
	end

	for _, Descendant in ipairs(Character:GetDescendants()) do
		if Descendant:IsA("BasePart") then
			Descendant.AssemblyLinearVelocity = Vector3.zero
			Descendant.AssemblyAngularVelocity = Vector3.zero
		end
	end
end

local function ApplySpectatorHumanoidProtection(Humanoid)
	if not Humanoid then
		return
	end

	if not SpectatorHumanoidStates[Humanoid] then
		local DeadStateEnabled = true
		pcall(function()
			DeadStateEnabled = Humanoid:GetStateEnabled(Enum.HumanoidStateType.Dead)
		end)

		SpectatorHumanoidStates[Humanoid] = {
			BreakJointsOnDeath = Humanoid.BreakJointsOnDeath,
			AutoRotate = Humanoid.AutoRotate,
			DeadStateEnabled = DeadStateEnabled,
		}
	end

	Humanoid.BreakJointsOnDeath = false
	Humanoid.AutoRotate = false
	pcall(function()
		Humanoid:SetStateEnabled(Enum.HumanoidStateType.Dead, false)
	end)
end

local function RestoreSpectatorHumanoidStates()
	for Humanoid, State in pairs(SpectatorHumanoidStates) do
		if Humanoid and Humanoid.Parent then
			Humanoid.BreakJointsOnDeath = State.BreakJointsOnDeath
			Humanoid.AutoRotate = State.AutoRotate
			pcall(function()
				Humanoid:SetStateEnabled(Enum.HumanoidStateType.Dead, State.DeadStateEnabled)
			end)
		end
	end

	table.clear(SpectatorHumanoidStates)
end

local function DisconnectSpectatorCameraConnections()
	for _, Connection in ipairs(SpectatorCameraConnections) do
		Connection:Disconnect()
	end

	table.clear(SpectatorCameraConnections)
end

local function RestoreSpectatorPartStates()
	for Part, State in pairs(SpectatorPartStates) do
		if Part and Part.Parent then
			Part.CanCollide = State.CanCollide
			Part.CanTouch = State.CanTouch
			Part.CanQuery = State.CanQuery
			Part.LocalTransparencyModifier = State.LocalTransparencyModifier
		end
	end

	table.clear(SpectatorPartStates)
end

local function MoveRealCharacterBelowPreview(PreviewCFrame)
	local RealCharacter = SpectatorRealCharacter
	local RealRoot = SpectatorRealRoot

	if not PreviewCFrame or not RealCharacter or not RealCharacter.Parent or not RealRoot or not RealRoot.Parent then
		return
	end

	local RealHumanoid = RealCharacter:FindFirstChildOfClass("Humanoid")
	ApplySpectatorHumanoidProtection(RealHumanoid)

	for _, Descendant in ipairs(RealCharacter:GetDescendants()) do
		if Descendant:IsA("BasePart") then
			if not SpectatorPartStates[Descendant] then
				SpectatorPartStates[Descendant] = {
					CanCollide = Descendant.CanCollide,
					CanTouch = Descendant.CanTouch,
					CanQuery = Descendant.CanQuery,
					LocalTransparencyModifier = Descendant.LocalTransparencyModifier,
				}
			end

			Descendant.CanCollide = false
			Descendant.CanTouch = false
			Descendant.CanQuery = false
			Descendant.LocalTransparencyModifier = 1
		end
	end

	local BelowPosition = PreviewCFrame.Position - Vector3.new(0, SpectatorDepth, 0)
	local MinimumSafeY = workspace.FallenPartsDestroyHeight + 8
	if BelowPosition.Y <= MinimumSafeY then
		BelowPosition = Vector3.new(BelowPosition.X, MinimumSafeY, BelowPosition.Z)
	end

	local BelowCFrame = CFrame.new(BelowPosition) * PreviewCFrame.Rotation

	RealRoot.AssemblyLinearVelocity = Vector3.zero
	RealRoot.AssemblyAngularVelocity = Vector3.zero
	RealCharacter:PivotTo(BelowCFrame)
	RealRoot.CFrame = BelowCFrame
	RealRoot.AssemblyLinearVelocity = Vector3.zero
	RealRoot.AssemblyAngularVelocity = Vector3.zero
end

local function AdoptCurrentCharacterForSpectator(PreviewCFrame)
	local CurrentCharacter = LocalPlayer.Character
	local CurrentHumanoid = CurrentCharacter and CurrentCharacter:FindFirstChildOfClass("Humanoid")
	local CurrentRoot = CurrentCharacter and CurrentCharacter:FindFirstChild("HumanoidRootPart")

	if not CurrentCharacter or not CurrentCharacter.Parent or not CurrentHumanoid or not CurrentRoot then
		return false
	end

	if CurrentCharacter ~= SpectatorRealCharacter or CurrentRoot ~= SpectatorRealRoot then
		RestoreSpectatorPartStates()
		RestoreSpectatorHumanoidStates()
		SpectatorRealCharacter = CurrentCharacter
		SpectatorRealRoot = CurrentRoot
		table.clear(SpectatorPartStates)
	end

	ApplySpectatorHumanoidProtection(CurrentHumanoid)
	MoveRealCharacterBelowPreview(PreviewCFrame)
	return true
end

local function DisableSpectator()
	if not SpectatorEnabled then
		return
	end

	local Clone = SpectatorClone
	local RealCharacter = SpectatorRealCharacter
	local FinalCFrame = Clone and Clone.Parent and Clone:GetPivot() or nil

	SpectatorEnabled = false
	SetSpectatorButtonState(false)
	RunService:UnbindFromRenderStep(SpectatorRenderBindingName)
	RunService:UnbindFromRenderStep(SpectatorFinalBindingName)
	RunService:UnbindFromRenderStep(SpectatorBodyBindingName)
	DisconnectSpectatorCameraConnections()

	if RealCharacter and RealCharacter.Parent then
		ClearCharacterVelocity(RealCharacter)

		if FinalCFrame then
			RealCharacter:PivotTo(FinalCFrame)
		end

		ClearCharacterVelocity(RealCharacter)
		RestoreSpectatorPartStates()
		RestoreSpectatorHumanoidStates()
		ClearCharacterVelocity(RealCharacter)

		task.defer(function()
			if RealCharacter and RealCharacter.Parent then
				ClearCharacterVelocity(RealCharacter)
			end
		end)

	else
		table.clear(SpectatorPartStates)
		RestoreSpectatorHumanoidStates()
	end

	CurrentCamera = workspace.CurrentCamera or CurrentCamera
	local CurrentCharacter = LocalPlayer.Character
	local CurrentHumanoid = CurrentCharacter and CurrentCharacter:FindFirstChildOfClass("Humanoid")
	local CameraSubject = SpectatorOriginalCameraSubject

	if not CameraSubject or not CameraSubject.Parent or (Clone and CameraSubject:IsDescendantOf(Clone)) then
		CameraSubject = CurrentHumanoid
	end

	if SpectatorOriginalCameraType then
		CurrentCamera.CameraType = SpectatorOriginalCameraType
	end

	if CameraSubject then
		CurrentCamera.CameraSubject = CameraSubject
	end

	StopSpectatorAnimations()

	if Clone then
		Clone:Destroy()
	end

	SpectatorClone = nil
	SpectatorRealCharacter = nil
	SpectatorRealRoot = nil
	SpectatorOriginalCameraSubject = nil
	SpectatorOriginalCameraType = nil

	if SpectatorPreviousTargeting and CurrentHumanoid and CurrentHumanoid.Health > 0 then
		SetTargetingState(true, "Move the circle near a player, then click")
	else
		StatusLabel.Text = "Spectator disabled"
		StatusLabel.TextColor3 = Color3.fromRGB(160, 160, 170)
	end

	SpectatorPreviousTargeting = false
end

local function EnableSpectator()
	if SpectatorEnabled then
		return
	end

	local RealCharacter = LocalPlayer.Character
	local RealHumanoid = RealCharacter and RealCharacter:FindFirstChildOfClass("Humanoid")
	local RealRoot = RealCharacter and RealCharacter:FindFirstChild("HumanoidRootPart")

	if not RealCharacter or not RealHumanoid or RealHumanoid.Health <= 0 or not RealRoot then
		StatusLabel.Text = "Character is not ready"
		StatusLabel.TextColor3 = Color3.fromRGB(255, 170, 105)
		return
	end

	RealCharacter.Archivable = true
	for _, Child in ipairs(RealCharacter:GetChildren()) do
		if Child:IsA("Tool") then
			Child.Archivable = true

			for _, Descendant in ipairs(Child:GetDescendants()) do
				Descendant.Archivable = true
			end
		end
	end

	local Clone = RealCharacter:Clone()
	local CloneHumanoid = Clone:FindFirstChildOfClass("Humanoid")
	local CloneRoot = Clone:FindFirstChild("HumanoidRootPart")

	if not CloneHumanoid or not CloneRoot then
		Clone:Destroy()
		StatusLabel.Text = "Could not create spectator preview"
		StatusLabel.TextColor3 = Color3.fromRGB(255, 170, 105)
		return
	end

	Clone.Name = "_StaffSpectatorPreview"

	for _, Descendant in ipairs(Clone:GetDescendants()) do
		if Descendant:IsA("Highlight") then
			Descendant:Destroy()
		elseif Descendant:IsA("Script") or Descendant:IsA("ModuleScript") then
			Descendant:Destroy()
		elseif Descendant:IsA("LocalScript") and Descendant.Name ~= "Animate" then
			Descendant:Destroy()
		elseif Descendant:IsA("BasePart") then
			Descendant.Transparency = math.max(Descendant.Transparency, SpectatorTransparency)
			Descendant.LocalTransparencyModifier = 0
			Descendant.CanCollide = false
			Descendant.CanTouch = false
			Descendant.CanQuery = false
		elseif Descendant:IsA("Decal") then
			Descendant.Transparency = math.max(Descendant.Transparency, SpectatorTransparency)
		end
	end

	local CloneAnimate = Clone:FindFirstChild("Animate")
	if CloneAnimate and CloneAnimate:IsA("LocalScript") then
		CloneAnimate.Disabled = true
	end

	CloneHumanoid.DisplayDistanceType = Enum.HumanoidDisplayDistanceType.None
	CloneHumanoid.BreakJointsOnDeath = false
	CloneHumanoid.AutoRotate = false
	Clone.Parent = workspace
	local PreviewStartCFrame = RealCharacter:GetPivot()
	Clone:PivotTo(PreviewStartCFrame)
	CloneRoot.Anchored = true
	LoadSpectatorAnimations(RealCharacter, CloneHumanoid)

	table.clear(SpectatorPartStates)
	for _, Descendant in ipairs(RealCharacter:GetDescendants()) do
		if Descendant:IsA("BasePart") then
			SpectatorPartStates[Descendant] = {
				CanCollide = Descendant.CanCollide,
				CanTouch = Descendant.CanTouch,
				CanQuery = Descendant.CanQuery,
				LocalTransparencyModifier = Descendant.LocalTransparencyModifier,
			}
			Descendant.CanCollide = false
			Descendant.CanTouch = false
			Descendant.CanQuery = false
			Descendant.LocalTransparencyModifier = 1
		end
	end

	SpectatorClone = Clone
	SpectatorRealCharacter = RealCharacter
	SpectatorRealRoot = RealRoot
	SpectatorOriginalCameraSubject = CurrentCamera.CameraSubject
	SpectatorOriginalCameraType = CurrentCamera.CameraType
	SpectatorPreviousTargeting = TargetingEnabled
	SpectatorEnabled = true
	ApplySpectatorHumanoidProtection(RealHumanoid)

	MoveRealCharacterBelowPreview(PreviewStartCFrame)
	SetTargetingState(false, "Spectator active")
	SetSpectatorButtonState(true)
	CurrentCamera.CameraType = Enum.CameraType.Custom
	CurrentCamera.CameraSubject = CloneHumanoid
	RunService:UnbindFromRenderStep(SpectatorRenderBindingName)
	RunService:UnbindFromRenderStep(SpectatorFinalBindingName)
	RunService:UnbindFromRenderStep(SpectatorBodyBindingName)
	DisconnectSpectatorCameraConnections()

	local function EnforceSpectatorBody()
		if not SpectatorEnabled or not SpectatorClone or not SpectatorClone.Parent then
			return
		end

		local PreviewCFrame = SpectatorClone:GetPivot()
		AdoptCurrentCharacterForSpectator(PreviewCFrame)
		MoveRealCharacterBelowPreview(PreviewCFrame)
	end

	local function EnforceSpectatorView()
		if not SpectatorEnabled or not SpectatorClone or not SpectatorClone.Parent then
			return
		end

		CurrentCamera = workspace.CurrentCamera or CurrentCamera
		local PreviewHumanoid = SpectatorClone:FindFirstChildOfClass("Humanoid")

		if PreviewHumanoid then
			CurrentCamera.CameraType = Enum.CameraType.Custom
			if CurrentCamera.CameraSubject ~= PreviewHumanoid then
				CurrentCamera.CameraSubject = PreviewHumanoid
			end
		end

		EnforceSpectatorBody()
	end

	RunService:BindToRenderStep(SpectatorBodyBindingName, Enum.RenderPriority.First.Value, EnforceSpectatorBody)
	RunService:BindToRenderStep(SpectatorRenderBindingName, Enum.RenderPriority.Camera.Value - 1, EnforceSpectatorView)
	RunService:BindToRenderStep(SpectatorFinalBindingName, Enum.RenderPriority.Last.Value, EnforceSpectatorView)

	table.insert(SpectatorCameraConnections, workspace:GetPropertyChangedSignal("CurrentCamera"):Connect(function()
		CurrentCamera = workspace.CurrentCamera or CurrentCamera
		EnforceSpectatorView()
	end))

	table.insert(SpectatorCameraConnections, CurrentCamera:GetPropertyChangedSignal("CameraSubject"):Connect(function()
		if SpectatorEnabled then
			EnforceSpectatorView()
		end
	end))

	StatusLabel.Text = "Spectator active — preview is local only"
	StatusLabel.TextColor3 = Color3.fromRGB(185, 145, 255)
end

local function UpdateSpectator(DeltaTime)
	if not SpectatorEnabled then
		return
	end

	local Clone = SpectatorClone

	if Clone and Clone.Parent and LocalPlayer.Character ~= SpectatorRealCharacter then
		AdoptCurrentCharacterForSpectator(Clone:GetPivot())
	end

	local RealCharacter = SpectatorRealCharacter
	local RealRoot = SpectatorRealRoot
	local RealHumanoid = RealCharacter and RealCharacter:FindFirstChildOfClass("Humanoid")
	local CloneHumanoid = Clone and Clone:FindFirstChildOfClass("Humanoid")
	local CloneRoot = Clone and Clone:FindFirstChild("HumanoidRootPart")

	if not Clone or not Clone.Parent or not CloneHumanoid or not CloneRoot then
		DisableSpectator()
		return
	end

	-- Keep the preview and camera alive while Roblox replaces the real character.
	-- The new character is adopted and moved underneath as soon as it exists.
	if not RealCharacter or not RealCharacter.Parent or not RealHumanoid or not RealRoot or not RealRoot.Parent or RealHumanoid.Health <= 0 then
		StatusLabel.Text = "Spectator active — recovering character"
		StatusLabel.TextColor3 = Color3.fromRGB(185, 145, 255)
		return
	end

	local MoveDirection = RealHumanoid.MoveDirection
	local HorizontalDirection = Vector3.new(MoveDirection.X, 0, MoveDirection.Z)
	local VerticalDirection = 0

	if UserInputService:IsKeyDown(Enum.KeyCode.Space) or UserInputService:IsKeyDown(Enum.KeyCode.E) then
		VerticalDirection += 1
	end

	if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl)
		or UserInputService:IsKeyDown(Enum.KeyCode.RightControl)
		or UserInputService:IsKeyDown(Enum.KeyCode.Q) then
		VerticalDirection -= 1
	end

	local StepTime = math.min(DeltaTime or 0, 0.05)
	local PreviewCFrame = Clone:GetPivot()
	local Movement = HorizontalDirection * SpectatorMoveSpeed
		+ Vector3.new(0, VerticalDirection * SpectatorVerticalSpeed, 0)
	local PreviewPosition = PreviewCFrame.Position + Movement * StepTime
	local PreviewRotation = PreviewCFrame.Rotation

	if HorizontalDirection.Magnitude > 0.05 then
		PreviewRotation = CFrame.lookAt(Vector3.zero, HorizontalDirection.Unit).Rotation
	end

	PreviewCFrame = CFrame.new(PreviewPosition) * PreviewRotation
	Clone:PivotTo(PreviewCFrame)
	UpdateSpectatorAnimation(HorizontalDirection.Magnitude, VerticalDirection)

	MoveRealCharacterBelowPreview(PreviewCFrame)
end

local function IsPointerOverStaffGui(PointerPosition)
	for _, GuiObject in ipairs(PlayerGui:GetGuiObjectsAtPosition(PointerPosition.X, PointerPosition.Y)) do
		if GuiObject:IsDescendantOf(ScreenGui) and GuiObject ~= TargetCircle and not GuiObject:IsDescendantOf(TargetCircle) then
			return true
		end
	end

	return false
end

local function FireAtPointer(PointerPosition)
	if not TargetingEnabled or IsPointerOverStaffGui(PointerPosition) then
		return
	end

	if os.clock() - LastShotTime < ClickDebounce then
		return
	end

	local Gun, Shoot, OriginAttachment = GetEquippedGun()
	if not Gun then
		StatusLabel.Text = "Equip Gun before clicking"
		StatusLabel.TextColor3 = Color3.fromRGB(255, 170, 105)
		return
	end

	local TargetPlayer, AimPart = FindTargetNearPointer(PointerPosition, OriginAttachment.WorldPosition)
	if not TargetPlayer or not AimPart then
		local HoveredPlayer = FindHoveredPlayerNearPointer(PointerPosition)
		StatusLabel.Text = HoveredPlayer
			and (HoveredPlayer.DisplayName .. " is blocked by a wall")
			or "No player touching the circle"
		StatusLabel.TextColor3 = Color3.fromRGB(255, 170, 105)
		return
	end

	LastShotTime = os.clock()
	local TargetCharacter = TargetPlayer.Character
	if not TargetCharacter or not AimPart:IsDescendantOf(TargetCharacter) then
		return
	end

	local PredictedPosition = GetPredictedAimPosition(TargetCharacter, AimPart)
	Shoot:FireServer(OriginAttachment.WorldCFrame, CFrame.new(PredictedPosition))
	StatusLabel.Text = "Shot sent to " .. TargetPlayer.DisplayName
	StatusLabel.TextColor3 = Color3.fromRGB(130, 235, 160)
end

