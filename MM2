local function UpdateDrag(Input)
	local Delta = Input.Position - DragStart
	MainFrame.Position = UDim2.new(
		StartPosition.X.Scale,
		StartPosition.X.Offset + Delta.X,
		StartPosition.Y.Scale,
		StartPosition.Y.Offset + Delta.Y
	)
end

local function UpdatePrediction(ScreenX)
	local TrackWidth = math.max(SliderTrack.AbsoluteSize.X, 1)
	local Alpha = math.clamp((ScreenX - SliderTrack.AbsolutePosition.X) / TrackWidth, 0, 1)
	PredictionTime = MinimumPrediction + (MaximumPrediction - MinimumPrediction) * Alpha
	PredictionTime = math.round(PredictionTime * 100) / 100
	Alpha = (PredictionTime - MinimumPrediction) / (MaximumPrediction - MinimumPrediction)

	SliderFill.Size = UDim2.fromScale(Alpha, 1)
	SliderKnob.Position = UDim2.fromScale(Alpha, 0.5)
	PredictionLabel.Text = string.format("Prediction: %.2fs", PredictionTime)
end

local function BeginSlider(Input)
	if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then
		SliderDragging = true
		SliderInput = Input
		UpdatePrediction(Input.Position.X)
	end
end

SliderTrack.InputBegan:Connect(BeginSlider)
SliderKnob.InputBegan:Connect(BeginSlider)

TitleBar.InputBegan:Connect(function(Input)
	if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then
		Dragging = true
		DragStart = Input.Position
		StartPosition = MainFrame.Position

		Input.Changed:Connect(function()
			if Input.UserInputState == Enum.UserInputState.End then
				Dragging = false
			end
		end)
	end
end)

TitleBar.InputChanged:Connect(function(Input)
	if Input.UserInputType == Enum.UserInputType.MouseMovement or Input.UserInputType == Enum.UserInputType.Touch then
		DragInput = Input
	end
end)

UserInputService.InputChanged:Connect(function(Input)
	if Dragging and Input == DragInput then
		UpdateDrag(Input)
	end

	if Input.UserInputType == Enum.UserInputType.Touch then
		LastTouchPosition = Vector2.new(Input.Position.X, Input.Position.Y)
	end

	if SliderDragging and (Input == SliderInput or Input.UserInputType == Enum.UserInputType.MouseMovement) then
		UpdatePrediction(Input.Position.X)
	end
end)

UserInputService.InputEnded:Connect(function(Input)
	if Input == SliderInput or Input.UserInputType == Enum.UserInputType.MouseButton1 then
		SliderDragging = false
		SliderInput = nil
	end
end)

